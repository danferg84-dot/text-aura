# ─── Text Aura environment ───────────────────────────────────────────────
# Anthropic API key for live persona transformations.
# Leave this UNSET to run the app in "Sandbox Demo Mode" — it falls back to
# curated client-side templates so the app is fully interactive out of the box.
#
# Copy this file to ".env" and drop in your key:
#   cp .env.example .env
#
# NOTE: This VITE_ var is the OLD direct-from-browser path and is no longer used —
# live AI now runs through the serverless function (api/transform.js), which reads
# server-side env vars instead (see below). Kept here only for reference.
VITE_AI_API_KEY=

# ─── Server-side env vars (set these in Vercel → Settings → Environment Variables,
#     NOT here — no VITE_ prefix, so they never reach the browser) ──────────────
#
# ANTHROPIC_API_KEY=sk-ant-...              # live AI (else Sandbox Demo Mode)
# SUPABASE_URL=https://xxxx.supabase.co     # Project URL (Supabase → Settings → API)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...          # service_role key (SECRET — server only)
# UNLIMITED_DEVICE_IDS=id1,id2              # device ids that bypass metering (your testing)
#
# Run supabase/schema.sql once in the Supabase SQL editor to create the tables/RPCs.
